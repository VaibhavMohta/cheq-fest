rules_version = '2';

// CHEQ Fest — Firestore security rules.
// Public read for events/teams/leaderboard/matches/sports/rulebook;
// authenticated writes only, role-gated. Full coverage lands as roles are wired.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isCheqEmail() {
      return isSignedIn() && request.auth.token.email.matches('.*@cheq[.]one$');
    }
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.superAdmin == true;
    }
    function isAdmin() {
      return isSignedIn() && (request.auth.token.admin == true || isSuperAdmin());
    }
    // The signed-in user is the Group Captain of (eventId, teamId).
    // GC membership is stored as an email on the team doc — survives the
    // staged → claimed sign-in transition without rewriting team docs.
    function isGroupCaptainOfTeam(eventId, teamId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/events/$(eventId)/teams/$(teamId))
          .data.groupCaptainEmail == request.auth.token.email;
    }
    // Event is "locked" for non-admin lineup edits once its start date
    // has arrived. Captains can finalise rosters before the event
    // begins, but only admins / super-admins can shuffle players once
    // the fest is live. A missing startDate is treated as unlocked
    // (draft event, dates not yet set).
    function isEventLocked(eventId) {
      let ev = get(/databases/$(database)/documents/events/$(eventId)).data;
      return ev.startDate != null && ev.startDate <= request.time;
    }

    // Cross-event roster reads needed for the `useRole()` collectionGroup
    // query that detects sport captaincy. The per-event match below
    // already authorises direct reads/writes; this wildcard-path rule
    // exists *only* to authorise collectionGroup('rosters') reads.
    //
    // We allow any signed-in user to read these because the data is the
    // same public data the per-event rule already opens up. Writes stay
    // gated by the per-event rule.
    match /{path=**}/rosters/{sportId} {
      allow read: if true;
    }

    // Public reads, admin-only writes on the event tree.
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();

      match /sports/{sportId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /teams/{teamId} {
        allow read: if true;
        // Admin: full write. Group Captain of this team may update the
        // team doc only if the change is constrained to viceCaptainEmail
        // — protects color, members, GC self, totalPoints, etc.
        allow create, delete: if isAdmin();
        allow update: if isAdmin()
                      || (isGroupCaptainOfTeam(eventId, teamId)
                          && !isEventLocked(eventId)
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viceCaptainEmail']));

        // Roster writes come from three places:
        //   - Admin / Super Admin: anything goes.
        //   - Group Captain of this team: assigns the Sport Captain.
        //   - Sport Captain of this (teamId, sportId): fills the four
        //     buckets in the lineup editor. Captain identity is stored as
        //     an email so staged → claimed transitions don't break.
        match /rosters/{sportId} {
          allow read: if true;
          allow write: if isAdmin()
                       || (!isEventLocked(eventId)
                           && (isGroupCaptainOfTeam(eventId, teamId)
                               || (isSignedIn()
                                   && get(/databases/$(database)/documents/events/$(eventId)/teams/$(teamId)/rosters/$(sportId))
                                        .data.sportCaptainEmail == request.auth.token.email)));
        }
      }

      match /matches/{matchId} {
        allow read: if true;
        allow write: if isAdmin();

        // Referees assigned to a match append events to the log.
        match /refereeEvents/{eventDocId} {
          allow read: if true;
          allow create, update: if isAdmin()
            || (isSignedIn()
                && request.auth.uid in
                   get(/databases/$(database)/documents/events/$(eventId)/matches/$(matchId))
                     .data.refereeUids);
        }
      }

      match /auditLog/{entryId} {
        allow read: if isAdmin();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }

      // Bonus awards — discretionary points granted directly by admins
      // (sportsmanship, attendance, penalties etc.). Public read so the
      // leaderboard can show the breakdown to everyone; admin-only writes.
      match /bonusAwards/{awardId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Users — each person can read/write their own doc; admin can write any.
    match /users/{uid} {
      allow read: if true;
      allow create: if isCheqEmail() && request.auth.uid == uid;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow delete: if isSuperAdmin();
    }

    // Staged players (pre-login CSV imports). Admin-only writes.
    match /stagedPlayers/{stagedId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // AI usage ledger — written by Cloud Functions (Admin SDK bypasses rules).
    // Admins read for the dashboard; nobody can write directly from the client.
    match /aiUsage/{usageId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
