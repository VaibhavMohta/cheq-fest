{
  "name": "cheq-fest",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "routes": "tsr generate",
    "build": "tsr generate && tsc -b && vite build",
    "build:dev": "tsr generate && tsc -b && vite build --mode development",
    "build:prod": "tsr generate && tsc -b && vite build --mode production",
    "deploy:dev": "pnpm build:dev && firebase deploy --project dev",
    "deploy:prod": "pnpm build:prod && firebase deploy --project prod",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsr generate && tsc -b --noEmit",
    "format": "prettier --write .",
    "emulators": "firebase emulators:start"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.95.0",
    "clsx": "^2.1.1",
    "firebase": "^11.3.0",
    "motion": "^11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-cli": "^1.95.0",
    "@tanstack/router-devtools": "^1.95.0",
    "@tanstack/router-plugin": "^1.95.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "packageManager": "pnpm@9.15.0"
}
